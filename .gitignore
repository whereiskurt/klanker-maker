# Go build artifacts
*.exe
*.test
*.bak

# macOS
.DS_Store

# Terraform / Terragrunt
.terraform/
.terraform.lock.hcl
.terragrunt-cache/

# Sandbox directories — per-sandbox generated dirs are ephemeral artifacts.
# The _template/ directory IS committed (contains the base terragrunt.hcl).
infra/live/sandboxes/sb-*/
infra/live/*/cluster-*/

infra/live/**/outputs.json
infra/live/*/sandboxes/*/
infra/live/*/region.hcl
infra/live/network/

# Build output directory (cross-compiled sidecar binaries)
build/
bin/

# GoReleaser output (cross-platform release archives + bundled tool staging)
dist/
# Bundled terraform/terragrunt staged by scripts/fetch-bundled-tools.sh (before-hook)
.extras/

