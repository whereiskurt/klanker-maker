# km-config.yaml — Platform configuration for klankrmkr
#
# Copy this file to km-config.yaml at the repo root and fill in your values.
# Never commit km-config.yaml to source control (it is listed in .gitignore).
#
# All values can also be set via KM_* environment variables (highest precedence).
# Example: KM_DOMAIN=mycompany.ai overrides the domain field below.

# domain: Base domain for the platform (e.g. "klankermaker.ai").
# Used for sandbox email addresses (sandboxes.{domain}), schema $id,
# and apiVersion prefixes. Required for DNS delegation setup.
domain: klankermaker.ai

# accounts: AWS account IDs for the multi-account topology.
accounts:
  # management: Root/management account ID. DNS NS records for the delegation
  # zone are added here. SSO is administered from this account.
  management: "111111111111"

  # terraform: Account used for Terraform state and infrastructure provisioning.
  # In a 2-account topology, set this to the same value as 'application'.
  terraform: "222222222222"

  # application: Account where sandbox resources (EC2, ECS, VPC) are created.
  application: "333333333333"

# sso: AWS IAM Identity Center (SSO) configuration.
sso:
  # start_url: Your SSO portal URL from the IAM Identity Center console.
  start_url: https://my-org.awsapps.com/start

  # region: AWS region where your SSO instance is hosted.
  region: us-east-1

# region: Default AWS region for infrastructure operations.
# Individual sandbox profiles can override this with spec.runtime.region.
region: us-east-1

# state_bucket: S3 bucket for Terraform state and sandbox metadata.
# Created during account setup; referenced by all km commands.
state_bucket: tf-km-state-use1

# artifacts_bucket: S3 bucket for Lambda zips, sidecar binaries, sandbox artifacts,
# and SES inbound email storage.
artifacts_bucket: km-artifacts-12345

# budget_table_name: DynamoDB table name for sandbox budget enforcement tracking.
# Defaults to "km-budgets" if not set.
budget_table_name: km-budgets

# identity_table_name: DynamoDB table name for sandbox identity (Ed25519 key pairs).
# Defaults to "km-identities" if not set.
identity_table_name: km-identities

# route53_zone_id: Route53 hosted zone ID for the domain.
# Used for DNS delegation and SES domain verification.
route53_zone_id: Z0123456789ABCDEFGHIJ

# operator_email: Email address for sandbox lifecycle notifications
# (created, destroyed, ttl-expired, budget-warning, etc.).
# Leave empty to disable notifications.
operator_email: ops@example.com

# safe_phrase: Shared secret for email-to-create authentication.
# Included in inbound emails to authorize sandbox creation via SES.
safe_phrase: my-secret-phrase

# max_sandboxes: Maximum number of concurrent sandboxes allowed.
# Set to 0 for unlimited. Defaults to 10.
max_sandboxes: 10
