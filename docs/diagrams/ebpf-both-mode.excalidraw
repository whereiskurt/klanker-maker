    },
    {
      "id": "legend-label",
      "type": "text",
      "x": 590,
      "y": 565,
      "width": 320,
      "height": 90,
      "text": "Legend\n■ Red:     BPF programs (kernel, in cgroup)\n■ Purple:  DNS resolver/proxy\n■ Orange:  L7 MITM proxy (Bedrock/GitHub/Anthropic)\n■ Teal:    SSL uprobe observer (Phase 41)\n■ Yellow:  BPF maps (shared kernel memory)\n■ Gray:    Audit pipeline (ring buffer → JSON → S3)",
      "fontSize": 10,
      "fontFamily": 3,
      "strokeColor": "#495057"
    }
