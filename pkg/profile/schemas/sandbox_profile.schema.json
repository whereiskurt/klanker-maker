{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://klankermaker.ai/schemas/sandbox-profile/v1alpha1",
  "title": "SandboxProfile",
  "description": "A declarative policy object that defines a controlled, auditable execution environment",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "type": "string",
      "pattern": "^.+/v1alpha1$",
      "description": "API version of the SandboxProfile resource (e.g. klankermaker.ai/v1alpha1)"
    },
    "kind": {
      "type": "string",
      "const": "SandboxProfile",
      "description": "Resource kind"
    },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Unique name for this profile"
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Arbitrary key-value labels for organization and filtering"
        },
        "prefix": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]{0,11}$",
          "description": "Optional sandbox ID prefix. Defaults to 'sb' when omitted."
        },
        "alias": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]{0,15}$",
          "description": "Optional alias template for sandbox. Auto-generates alias-1, alias-2, etc."
        }
      }
    },
    "extends": {
      "type": "string",
      "description": "Name of the parent profile to inherit from"
    },
    "spec": {
      "type": "object",
      "required": [
        "lifecycle",
        "runtime",
        "execution",
        "sourceAccess",
        "network",
        "identity",
        "sidecars",
        "observability",
        "policy",
        "agent"
      ],
      "additionalProperties": false,
      "properties": {
        "email": {
          "type": "object",
          "description": "Optional email signing, inbound verification, and encryption policy",
          "additionalProperties": false,
          "properties": {
            "signing": {
              "type": "string",
              "enum": ["required", "optional", "off"],
              "description": "Whether outbound emails must be signed (DKIM/Ed25519)"
            },
            "verifyInbound": {
              "type": "string",
              "enum": ["required", "optional", "off"],
              "description": "Whether inbound email signatures must be verified"
            },
            "encryption": {
              "type": "string",
              "enum": ["required", "optional", "off"],
              "description": "Whether email content must be encrypted"
            },
            "alias": {
              "type": "string",
              "description": "Human-friendly dot-notation name (e.g. 'research.team-a') registered in km-identities",
              "pattern": "^[a-z][a-z0-9-]*\\.[a-z][a-z0-9-]*$"
            },
            "allowedSenders": {
              "type": "array",
              "description": "Patterns controlling which sandboxes may send to this sandbox: 'self', sandbox IDs, alias wildcards (build.*), or '*'",
              "items": { "type": "string" }
            }
          }
        },
        "budget": {
          "type": "object",
          "description": "Optional spend limits for compute and AI workloads",
          "additionalProperties": false,
          "properties": {
            "compute": {
              "type": "object",
              "description": "Compute (EC2/Fargate) spend limit",
              "additionalProperties": false,
              "properties": {
                "maxSpendUSD": { "type": "number", "minimum": 0, "description": "Maximum compute spend in USD" }
              },
              "required": ["maxSpendUSD"]
            },
            "ai": {
              "type": "object",
              "description": "Bedrock AI model spend limit",
              "additionalProperties": false,
              "properties": {
                "maxSpendUSD": { "type": "number", "minimum": 0, "description": "Maximum AI spend in USD" }
              },
              "required": ["maxSpendUSD"]
            },
            "warningThreshold": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Fraction of limit at which warning alerts fire (default 0.8)"
            }
          }
        },
        "artifacts": {
          "type": "object",
          "description": "Optional artifact collection and S3 upload settings",
          "additionalProperties": false,
          "properties": {
            "paths": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Glob patterns or directory paths to collect as artifacts"
            },
            "maxSizeMB": {
              "type": "integer",
              "minimum": 0,
              "description": "Maximum file size in MB to upload; 0 means unlimited"
            },
            "replicationRegion": {
              "type": "string",
              "description": "Optional secondary AWS region to replicate artifacts to"
            }
          }
        },
        "lifecycle": {
          "type": "object",
          "required": ["ttl", "idleTimeout", "teardownPolicy"],
          "additionalProperties": false,
          "properties": {
            "ttl": {
              "type": "string",
              "pattern": "^[0-9]+(s|m|h|d)$",
              "description": "Maximum sandbox lifetime as a duration string (e.g. 24h)"
            },
            "idleTimeout": {
              "type": "string",
              "pattern": "^[0-9]+(s|m|h|d)$",
              "description": "Duration after which an idle sandbox is torn down"
            },
            "teardownPolicy": {
              "type": "string",
              "enum": ["destroy", "stop", "retain"],
              "description": "What happens when the sandbox expires"
            }
          }
        },
        "runtime": {
          "type": "object",
          "required": ["substrate", "instanceType", "region"],
          "additionalProperties": false,
          "properties": {
            "substrate": {
              "type": "string",
              "enum": ["ec2", "ecs", "docker"],
              "description": "Compute backend: ec2 (EC2 instance), ecs (Fargate task), or docker (local)"
            },
            "spot": {
              "type": "boolean",
              "description": "Use spot instances (EC2 only)"
            },
            "instanceType": {
              "type": "string",
              "minLength": 1,
              "description": "EC2 instance type or ECS task CPU/memory size"
            },
            "region": {
              "type": "string",
              "minLength": 1,
              "description": "AWS region to provision in"
            }
          }
        },
        "execution": {
          "type": "object",
          "required": ["shell", "workingDir"],
          "additionalProperties": false,
          "properties": {
            "shell": {
              "type": "string",
              "minLength": 1,
              "description": "Path to the shell executable"
            },
            "workingDir": {
              "type": "string",
              "minLength": 1,
              "description": "Initial working directory"
            },
            "useBedrock": {
              "type": "boolean",
              "description": "Route Anthropic API calls through AWS Bedrock instead of api.anthropic.com"
            },
            "env": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              },
              "description": "Additional environment variables to inject"
            },
            "initCommands": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Shell commands to run after sandbox starts, before user session"
            },
            "initScripts": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Local script file paths to upload to S3 and run on startup"
            },
            "rsync": {
              "type": "string",
              "description": "Name of a saved home directory snapshot to restore on boot (created via km rsync save)"
            },
            "rsyncPaths": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Paths relative to sandbox user $HOME to include in rsync snapshots. Shell wildcards supported (e.g. projects/*/config)."
            },
            "rsyncFileList": {
              "type": "string",
              "description": "Path to a local YAML file containing additional rsync paths (resolved from operator cwd at km rsync save time)."
            }
          }
        },
        "sourceAccess": {
          "type": "object",
          "required": ["mode"],
          "additionalProperties": false,
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["allowlist", "none"],
              "description": "Access mode: allowlist or none"
            },
            "github": {
              "type": "object",
              "required": ["allowedRepos"],
              "additionalProperties": false,
              "properties": {
                "allowedRepos": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "List of allowed GitHub repository patterns"
                },
                "allowedRefs": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "List of allowed git refs (branches, tags)"
                },
                "permissions": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": ["read", "write"]
                  },
                  "description": "Allowed permission levels"
                }
              }
            }
          }
        },
        "network": {
          "type": "object",
          "required": ["egress"],
          "additionalProperties": false,
          "properties": {
            "egress": {
              "type": "object",
              "required": ["allowedDNSSuffixes", "allowedHosts", "allowedMethods"],
              "additionalProperties": false,
              "properties": {
                "allowedDNSSuffixes": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "DNS suffix patterns allowed for resolution (e.g. .amazonaws.com)"
                },
                "allowedHosts": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Explicit hostnames allowed for egress"
                },
                "allowedMethods": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"]
                  },
                  "description": "HTTP methods permitted for egress"
                }
              }
            },
            "httpsOnly": {
              "type": "boolean",
              "description": "Block plain HTTP traffic; on EC2 security groups enforce this, on Docker the proxy enforces it"
            },
            "enforcement": {
              "type": "string",
              "enum": ["proxy", "ebpf", "both"],
              "default": "proxy",
              "description": "Network enforcement mechanism: proxy (iptables DNAT, default), ebpf (cgroup BPF, EC2-only), or both (eBPF primary + proxy for L7 inspection, EC2-only)"
            }
          }
        },
        "identity": {
          "type": "object",
          "required": ["roleSessionDuration", "allowedRegions", "sessionPolicy"],
          "additionalProperties": false,
          "properties": {
            "roleSessionDuration": {
              "type": "string",
              "pattern": "^[0-9]+(s|m|h)$",
              "description": "Maximum duration for assumed role sessions"
            },
            "allowedRegions": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1,
              "description": "AWS regions the sandbox may access"
            },
            "sessionPolicy": {
              "type": "string",
              "enum": ["minimal", "standard", "elevated"],
              "description": "IAM session policy scope"
            }
          }
        },
        "sidecars": {
          "type": "object",
          "required": ["dnsProxy", "httpProxy", "auditLog", "tracing"],
          "additionalProperties": false,
          "properties": {
            "dnsProxy": { "$ref": "#/$defs/SidecarConfig" },
            "httpProxy": { "$ref": "#/$defs/SidecarConfig" },
            "auditLog": { "$ref": "#/$defs/SidecarConfig" },
            "tracing": { "$ref": "#/$defs/SidecarConfig" }
          }
        },
        "observability": {
          "type": "object",
          "required": ["commandLog", "networkLog"],
          "additionalProperties": false,
          "properties": {
            "commandLog": { "$ref": "#/$defs/LogDestination" },
            "networkLog": { "$ref": "#/$defs/LogDestination" },
            "claudeTelemetry": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "description": "Enable Claude Code OpenTelemetry export (default: true)"
                },
                "logPrompts": {
                  "type": "boolean",
                  "description": "Include actual prompt text in telemetry (default: false)"
                },
                "logToolDetails": {
                  "type": "boolean",
                  "description": "Include tool parameters (bash commands, file paths) in telemetry (default: false)"
                }
              }
            }
          }
        },
        "policy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "allowShellEscape": {
              "type": "boolean",
              "description": "Permit shell escape sequences. Set false for hardened profiles."
            },
            "allowedCommands": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Allowlist of commands the agent may invoke"
            },
            "filesystemPolicy": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "readOnlyPaths": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Paths that are read-only within the sandbox"
                },
                "writablePaths": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Paths that are writable within the sandbox"
                }
              }
            }
          }
        },
        "agent": {
          "type": "object",
          "required": ["maxConcurrentTasks", "taskTimeout"],
          "additionalProperties": false,
          "properties": {
            "maxConcurrentTasks": {
              "type": "integer",
              "minimum": 1,
              "description": "Maximum number of parallel tasks the agent may run"
            },
            "taskTimeout": {
              "type": "string",
              "pattern": "^[0-9]+(s|m|h)$",
              "description": "Maximum duration for a single agent task"
            },
            "allowedTools": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Tool names the agent is permitted to use"
            }
          }
        }
      }
    }
  },
  "$defs": {
    "SidecarConfig": {
      "type": "object",
      "required": ["enabled", "image"],
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether this sidecar is active"
        },
        "image": {
          "type": "string",
          "minLength": 1,
          "description": "Container image reference for this sidecar"
        }
      }
    },
    "LogDestination": {
      "type": "object",
      "required": ["destination"],
      "additionalProperties": false,
      "properties": {
        "destination": {
          "type": "string",
          "enum": ["cloudwatch", "s3", "stdout"],
          "description": "Log backend destination"
        },
        "logGroup": {
          "type": "string",
          "description": "CloudWatch log group or S3 prefix"
        }
      }
    }
  }
}
